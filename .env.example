# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Talo (pagos ARS por transferencia) — server only, JAMÁS exponer en frontend
TALO_CLIENT_ID=
TALO_CLIENT_SECRET=
TALO_USER_ID=
TALO_ENVIRONMENT=production   # production | sandbox

# URL pública de la app (webhook_url y redirect_url de Talo)
NEXT_PUBLIC_APP_URL=https://timon-xi.vercel.app

# Azure Functions (agente de assessments) — server only
# AZURE_BASE_URL: base SIN /api/assessments. Si falta, el código cae a la URL
# histórica (cuenta personal anterior) y loguea un warning. Tras migrar la
# cuenta de Azure, setearla en Vercel es OBLIGATORIO para no seguir llamando
# a la cuenta vieja.
AZURE_BASE_URL=
AZURE_FUNCTIONS_KEY=
# Timeouts por request a Azure (ms). Defaults: poll 10000, submit 55000.
AZURE_POLL_TIMEOUT_MS=
AZURE_SUBMIT_TIMEOUT_MS=

# Cron de reconciliación (GET /api/cron/reconcile-assessments)
# CRON_SECRET: mismo valor acá (Vercel) y en GitHub → Settings → Secrets →
# Actions. RECONCILE_URL NO es una env de la app: vive solo en GitHub Actions
# Secrets (ver .github/workflows/reconcile.yml).
CRON_SECRET=
# Tope duro en minutos para marcar failed un processing eterno (0/vacío = off)
RECONCILE_HARD_TIMEOUT_MIN=

# PostHog (analytics + session replay). Sin key es un no-op (dev/tests).
NEXT_PUBLIC_POSTHOG_KEY=

# E2E
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
